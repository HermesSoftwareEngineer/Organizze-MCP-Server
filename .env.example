# Credenciais da API do Organizze
# Obtenha seu token em: https://app.organizze.com.br/configuracoes/api-keys
ORGANIZZE_EMAIL=seu@email.com
ORGANIZZE_API_TOKEN=seu_token_aqui

# Transporte: 'stdio' (Claude Desktop local) | 'sse' (Cloud Run / remoto)
TRANSPORT=stdio

# Token de autenticação do endpoint SSE — obrigatório em produção no Cloud Run
# Gere com: python -c "import secrets; print(secrets.token_hex(32))"
MCP_AUTH_TOKEN=
